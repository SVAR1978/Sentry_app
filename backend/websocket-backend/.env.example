# Server config
PORT=8080

# External services
POLICE_STATION_LOCATION_URL=
POLICE_STATION_BOUNDARY_URL=
AWS_RISK_BASE_URL=
# Redis (for caching and Pub/Sub if needed)
REDIS_URL=redis://localhost:6379

# Database config (if websocket server connects directly to db)
DATABASE_URL=postgresql://user:password@localhost:5432/sentry

# JWT secret for auth verification
JWT_SECRET=super_secret_jwt_key_here

# Email sending (required for SOS emails)
FROM_EMAIL=no-reply@example.com
FROM_NAME="Sentry Alerts"
BREVO_API_KEY=your_brevo_api_key_here

# Set true to run email worker inside websocket service process
RUN_EMAIL_WORKER=false
